# Copy this file to .env and fill in your values
# cp .env.example .env

# Authentication: Claude Max (x20) - login happens interactively inside container
# First run: docker attach claude-dev -> claude login

# Optional: Git identity for commits inside the container
GIT_USER_NAME=Your Name
GIT_USER_EMAIL=your@email.com

# SonarQube (dostepny z kontenera jako host.docker.internal:9000)
SONAR_HOST_URL=http://host.docker.internal:9000
SONAR_LOGIN=admin
SONAR_PASSWORD=admin
