{
  "permissions": {
    "allow": ["*"],
    "deny": []
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash /opt/claude/hooks/pre-merge-review.sh",
            "timeout": 300
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash /opt/claude/hooks/post-merge-cleanup.sh",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
